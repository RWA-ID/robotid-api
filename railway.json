{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "api/**",
      "nixpacks.toml",
      "railway.json",
      "package.json",
      "package-lock.json"
    ]
  },
  "deploy": {
    "startCommand": "node api/dist/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
