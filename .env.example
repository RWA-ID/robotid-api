# ── Chain / RPC ──────────────────────────────────────────────────────────────
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_API_KEY=
CHAIN_ID=1

# ── Contracts (filled after deploy) ──────────────────────────────────────────
ROBOT_IDENTITY_ADDRESS=
AGENT_WALLET_ADDRESS=
INTENT_ROUTER_ADDRESS=
CAPABILITY_REGISTRY_ADDRESS=
OTA_VERIFIER_ADDRESS=
MERKLE_ORACLE_ADDRESS=
SUBSCRIPTION_ADDRESS=

# ── Payments ─────────────────────────────────────────────────────────────────
USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
TREASURY_ADDRESS=

# ── ENS ──────────────────────────────────────────────────────────────────────
ENS_PARENT=robot-id.eth
NAMEWRAPPER_ADDRESS=0xD4416b13d2b3a9aBae7AcD5D6C2BbDBE25686401
PUBLIC_RESOLVER=0x231b0Ee14048e9dCcD1d247744d114a4EB5E8E63
REGISTRAR_OPERATOR=

# ── IPFS ─────────────────────────────────────────────────────────────────────
PINATA_JWT=

# ── Wallet / auth ────────────────────────────────────────────────────────────
REOWN_PROJECT_ID=

# ── API ──────────────────────────────────────────────────────────────────────
PORT=3001
# registrar / key-provisioning signer (SERVER-SIDE ONLY — never ship to frontend)
ADMIN_PRIVATE_KEY=
# Durable store. When set, API keys, batches, namespace reservations, and the
# rate/quota/unit counters live in Redis (survives restarts, shared across
# instances). Unset → in-memory fallback (single-process, non-durable).
# On Railway: add the Redis plugin and reference its connection string.
REDIS_URL=${{Redis.REDIS_URL}}

# ── Frontend (NEXT_PUBLIC_* are safe to expose) ──────────────────────────────
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_REOWN_PROJECT_ID=
NEXT_PUBLIC_API_URL=https://api.robot-id.eth
NEXT_PUBLIC_SUBSCRIPTION_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
