{
  "name": "@robot-id/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts || true",
    "test": "node --test --import tsx ./test/*.test.ts",
    "smoke": "bash src/scripts/oem-quickstart.sh"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-errors": "^3.1.1",
    "graphql": "^16.9.0",
    "graphql-http": "^1.22.3",
    "swagger-ui-express": "^5.0.1",
    "viem": "^2.21.45",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
