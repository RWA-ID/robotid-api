{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "[ -f package-lock.json ] || cd ..; npm ci --include=dev --workspaces --include-workspace-root",
  "buildCommand": "cd \"$(dirname \"$(find /vercel -maxdepth 5 -name next.config.js -not -path '*node_modules*'|head -1)\")\"&&npx --no-install next build&&rm -rf ../out&&cp -r out ../out",
  "outputDirectory": "out"
}
