{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "[ -f package-lock.json ] || cd ..; npm ci --include=dev --workspaces --include-workspace-root",
  "buildCommand": "bash \"$(find /vercel -maxdepth 4 -name vercel-build.sh -not -path '*node_modules*'|head -1)\"",
  "outputDirectory": "out"
}
