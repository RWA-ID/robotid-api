{
  "name": "@robot-id/intent-sdk",
  "version": "0.1.0",
  "description": "Convert natural-language / AI agent commands into on-chain robot actions via IntentRouter. Lead adapter: ros2-bridge.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts || true",
    "test": "node --test --import tsx ./test/*.test.ts || true"
  },
  "dependencies": {
    "@robot-id/sdk": "^0.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
